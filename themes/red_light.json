{
  "name": "Themixir Red Light",
  "type": "light",
  "colors": {
    "editor.background": "#F8F0F0",
    "editor.foreground": "#210909",
    "editor.selectionBackground": "#A62B2B80",
    "editor.lineHighlightBackground": "#F9F2F2",
    "editorCursor.foreground": "#A62B2B",
    "editorWhitespace.foreground": "#641A1A40",
    "editorIndentGuide.background": "#641A1A20",
    "editorIndentGuide.activeBackground": "#A62B2B60",
    "activityBar.background": "#F8F0F0",
    "activityBar.foreground": "#210909",
    "activityBar.inactiveForeground": "#21090960",
    "activityBarBadge.background": "#A62B2B",
    "activityBarBadge.foreground": "#F8F0F0",
    "sideBar.background": "#F9F2F2",
    "sideBar.foreground": "#210909",
    "sideBarSectionHeader.background": "#F8F0F0",
    "statusBar.background": "#A62B2B",
    "statusBar.foreground": "#F8F0F0",
    "statusBar.noFolderBackground": "#A62B2B",
    "titleBar.activeBackground": "#F8F0F0",
    "titleBar.activeForeground": "#210909",
    "tab.activeBackground": "#F8F0F0",
    "tab.activeForeground": "#210909",
    "tab.inactiveBackground": "#DFD8D8",
    "tab.inactiveForeground": "#21090980",
    "terminal.background": "#F8F0F0",
    "terminal.foreground": "#210909"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#641A1A"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#A62B2B"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#A62B2B"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#A62B2B",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#A62B2B"
      }
    },
    {
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#A62B2B"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#210909"
      }
    },
    {
      "scope": "punctuation",
      "settings": {
        "foreground": "#210909B0"
      }
    }
  ]
}