{
  "name": "Themixir Green Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#0D140D",
    "editor.foreground": "#E7EFDB",
    "editor.selectionBackground": "#88B04B80",
    "editor.lineHighlightBackground": "#0C120C",
    "editorCursor.foreground": "#88B04B",
    "editorWhitespace.foreground": "#6D8D3C40",
    "editorIndentGuide.background": "#6D8D3C20",
    "editorIndentGuide.activeBackground": "#88B04B60",
    "activityBar.background": "#0D140D",
    "activityBar.foreground": "#E7EFDB",
    "activityBar.inactiveForeground": "#E7EFDB60",
    "activityBarBadge.background": "#88B04B",
    "activityBarBadge.foreground": "#0D140D",
    "sideBar.background": "#0C120C",
    "sideBar.foreground": "#E7EFDB",
    "sideBarSectionHeader.background": "#0D140D",
    "statusBar.background": "#88B04B",
    "statusBar.foreground": "#0D140D",
    "statusBar.noFolderBackground": "#88B04B",
    "titleBar.activeBackground": "#0D140D",
    "titleBar.activeForeground": "#E7EFDB",
    "tab.activeBackground": "#0D140D",
    "tab.activeForeground": "#E7EFDB",
    "tab.inactiveBackground": "#0C120C",
    "tab.inactiveForeground": "#E7EFDB80",
    "terminal.background": "#0D140D",
    "terminal.foreground": "#E7EFDB"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#6D8D3C"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#88B04B"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#88B04B"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#88B04B",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#88B04B"
      }
    },
    {
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#88B04B"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#E7EFDB"
      }
    },
    {
      "scope": "punctuation",
      "settings": {
        "foreground": "#E7EFDBB0"
      }
    }
  ]
}