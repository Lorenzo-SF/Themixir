{
  "name": "Themixir Blue Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#0A0A12",
    "editor.foreground": "#CDF0F6",
    "editor.selectionBackground": "#06B6D480",
    "editor.lineHighlightBackground": "#090910",
    "editorCursor.foreground": "#06B6D4",
    "editorWhitespace.foreground": "#0592AA40",
    "editorIndentGuide.background": "#0592AA20",
    "editorIndentGuide.activeBackground": "#06B6D460",
    "activityBar.background": "#0A0A12",
    "activityBar.foreground": "#CDF0F6",
    "activityBar.inactiveForeground": "#CDF0F660",
    "activityBarBadge.background": "#06B6D4",
    "activityBarBadge.foreground": "#0A0A12",
    "sideBar.background": "#090910",
    "sideBar.foreground": "#CDF0F6",
    "sideBarSectionHeader.background": "#0A0A12",
    "statusBar.background": "#06B6D4",
    "statusBar.foreground": "#0A0A12",
    "statusBar.noFolderBackground": "#06B6D4",
    "titleBar.activeBackground": "#0A0A12",
    "titleBar.activeForeground": "#CDF0F6",
    "tab.activeBackground": "#0A0A12",
    "tab.activeForeground": "#CDF0F6",
    "tab.inactiveBackground": "#090910",
    "tab.inactiveForeground": "#CDF0F680",
    "terminal.background": "#0A0A12",
    "terminal.foreground": "#CDF0F6"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#0592AA"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#06B6D4"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#06B6D4"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#06B6D4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#06B6D4"
      }
    },
    {
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#06B6D4"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#CDF0F6"
      }
    },
    {
      "scope": "punctuation",
      "settings": {
        "foreground": "#CDF0F6B0"
      }
    }
  ]
}