{
  "name": "Themixir Silver Deep",
  "type": "dark",
  "colors": {
    "editor.background": "#222222",
    "editor.foreground": "#E5E5E5",
    "editor.selectionBackground": "#A9A9A980",
    "editor.lineHighlightBackground": "#1F1F1F",
    "editorCursor.foreground": "#A9A9A9",
    "editorWhitespace.foreground": "#87878740",
    "editorIndentGuide.background": "#87878720",
    "editorIndentGuide.activeBackground": "#A9A9A960",
    "activityBar.background": "#222222",
    "activityBar.foreground": "#E5E5E5",
    "activityBar.inactiveForeground": "#E5E5E560",
    "activityBarBadge.background": "#A9A9A9",
    "activityBarBadge.foreground": "#222222",
    "sideBar.background": "#1F1F1F",
    "sideBar.foreground": "#E5E5E5",
    "sideBarSectionHeader.background": "#222222",
    "statusBar.background": "#A9A9A9",
    "statusBar.foreground": "#222222",
    "statusBar.noFolderBackground": "#A9A9A9",
    "titleBar.activeBackground": "#222222",
    "titleBar.activeForeground": "#E5E5E5",
    "tab.activeBackground": "#222222",
    "tab.activeForeground": "#E5E5E5",
    "tab.inactiveBackground": "#1F1F1F",
    "tab.inactiveForeground": "#E5E5E580",
    "terminal.background": "#222222",
    "terminal.foreground": "#E5E5E5"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#878787"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#A9A9A9"
      }
    },
    {
      "scope": "string.regexp",
      "settings": {
        "foreground": "#A9A9A9"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#A9A9A9"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#A9A9A9",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#A9A9A9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#A9A9A9"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#A9A9A9",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#A9A9A9"
      }
    },
    {
      "scope": "entity.name.class",
      "settings": {
        "foreground": "#A9A9A9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "entity.name.type",
      "settings": {
        "foreground": "#A9A9A9"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#E5E5E5"
      }
    },
    {
      "scope": "variable.parameter",
      "settings": {
        "foreground": "#A9A9A9",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "variable.other.property",
      "settings": {
        "foreground": "#A9A9A9"
      }
    },
    {
      "scope": "punctuation",
      "settings": {
        "foreground": "#E5E5E5B0"
      }
    }
  ]
}