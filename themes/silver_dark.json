{
  "name": "Themixir Silver Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#121212",
    "editor.foreground": "#EEEEEE",
    "editor.selectionBackground": "#A9A9A980",
    "editor.lineHighlightBackground": "#101010",
    "editorCursor.foreground": "#A9A9A9",
    "editorWhitespace.foreground": "#87878740",
    "editorIndentGuide.background": "#87878720",
    "editorIndentGuide.activeBackground": "#A9A9A960",
    "activityBar.background": "#121212",
    "activityBar.foreground": "#EEEEEE",
    "activityBar.inactiveForeground": "#EEEEEE60",
    "activityBarBadge.background": "#A9A9A9",
    "activityBarBadge.foreground": "#121212",
    "sideBar.background": "#101010",
    "sideBar.foreground": "#EEEEEE",
    "sideBarSectionHeader.background": "#121212",
    "statusBar.background": "#A9A9A9",
    "statusBar.foreground": "#121212",
    "statusBar.noFolderBackground": "#A9A9A9",
    "titleBar.activeBackground": "#121212",
    "titleBar.activeForeground": "#EEEEEE",
    "tab.activeBackground": "#121212",
    "tab.activeForeground": "#EEEEEE",
    "tab.inactiveBackground": "#101010",
    "tab.inactiveForeground": "#EEEEEE80",
    "terminal.background": "#121212",
    "terminal.foreground": "#EEEEEE"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#878787"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#A9A9A9"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#A9A9A9"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#A9A9A9",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#A9A9A9"
      }
    },
    {
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#A9A9A9"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#EEEEEE"
      }
    },
    {
      "scope": "punctuation",
      "settings": {
        "foreground": "#EEEEEEB0"
      }
    }
  ]
}