{
  "name": "Themixir Magenta Light",
  "type": "light",
  "colors": {
    "editor.background": "#F0E6F0",
    "editor.foreground": "#270015",
    "editor.selectionBackground": "#C2006B80",
    "editor.lineHighlightBackground": "#F2E9F2",
    "editorCursor.foreground": "#C2006B",
    "editorWhitespace.foreground": "#74004040",
    "editorIndentGuide.background": "#74004020",
    "editorIndentGuide.activeBackground": "#C2006B60",
    "activityBar.background": "#F0E6F0",
    "activityBar.foreground": "#270015",
    "activityBar.inactiveForeground": "#27001560",
    "activityBarBadge.background": "#C2006B",
    "activityBarBadge.foreground": "#F0E6F0",
    "sideBar.background": "#F2E9F2",
    "sideBar.foreground": "#270015",
    "sideBarSectionHeader.background": "#F0E6F0",
    "statusBar.background": "#C2006B",
    "statusBar.foreground": "#F0E6F0",
    "statusBar.noFolderBackground": "#C2006B",
    "titleBar.activeBackground": "#F0E6F0",
    "titleBar.activeForeground": "#270015",
    "tab.activeBackground": "#F0E6F0",
    "tab.activeForeground": "#270015",
    "tab.inactiveBackground": "#D8CFD8",
    "tab.inactiveForeground": "#27001580",
    "terminal.background": "#F0E6F0",
    "terminal.foreground": "#270015"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#740040"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#C2000A"
      }
    },
    {
      "scope": "string.regexp",
      "settings": {
        "foreground": "#006BC2"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#00C257"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#00C257",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#C2006B",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#C2006B"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#00C257",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#6BC200"
      }
    },
    {
      "scope": "entity.name.class",
      "settings": {
        "foreground": "#C2B800",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "entity.name.type",
      "settings": {
        "foreground": "#00C257"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#270015"
      }
    },
    {
      "scope": "variable.parameter",
      "settings": {
        "foreground": "#B800C2",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "variable.other.property",
      "settings": {
        "foreground": "#0AC200"
      }
    },
    {
      "scope": "punctuation",
      "settings": {
        "foreground": "#270015B0"
      }
    }
  ]
}