{
  "name": "Themixir Magenta Deep",
  "type": "dark",
  "colors": {
    "editor.background": "#33001D",
    "editor.foreground": "#FFB3DE",
    "editor.selectionBackground": "#FF009080",
    "editor.lineHighlightBackground": "#2E001A",
    "editorCursor.foreground": "#FF0090",
    "editorWhitespace.foreground": "#CC007340",
    "editorIndentGuide.background": "#CC007320",
    "editorIndentGuide.activeBackground": "#FF009060",
    "activityBar.background": "#33001D",
    "activityBar.foreground": "#FFB3DE",
    "activityBar.inactiveForeground": "#FFB3DE60",
    "activityBarBadge.background": "#FF0090",
    "activityBarBadge.foreground": "#33001D",
    "sideBar.background": "#2E001A",
    "sideBar.foreground": "#FFB3DE",
    "sideBarSectionHeader.background": "#33001D",
    "statusBar.background": "#FF0090",
    "statusBar.foreground": "#33001D",
    "statusBar.noFolderBackground": "#FF0090",
    "titleBar.activeBackground": "#33001D",
    "titleBar.activeForeground": "#FFB3DE",
    "tab.activeBackground": "#33001D",
    "tab.activeForeground": "#FFB3DE",
    "tab.inactiveBackground": "#2E001A",
    "tab.inactiveForeground": "#FFB3DE80",
    "terminal.background": "#33001D",
    "terminal.foreground": "#FFB3DE"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#CC0073"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#FF0010"
      }
    },
    {
      "scope": "string.regexp",
      "settings": {
        "foreground": "#0090FF"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#00FF6F"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#00FF6F",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#FF0090",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#FF0090"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#00FF6F",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#90FF00"
      }
    },
    {
      "scope": "entity.name.class",
      "settings": {
        "foreground": "#FFEF00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "entity.name.type",
      "settings": {
        "foreground": "#00FF6F"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#FFB3DE"
      }
    },
    {
      "scope": "variable.parameter",
      "settings": {
        "foreground": "#EF00FF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "variable.other.property",
      "settings": {
        "foreground": "#10FF00"
      }
    },
    {
      "scope": "punctuation",
      "settings": {
        "foreground": "#FFB3DEB0"
      }
    }
  ]
}