{
  "name": "Themixir Silver Light",
  "type": "light",
  "colors": {
    "editor.background": "#F0F0F0",
    "editor.foreground": "#1A1A1A",
    "editor.selectionBackground": "#80808080",
    "editor.lineHighlightBackground": "#F2F2F2",
    "editorCursor.foreground": "#808080",
    "editorWhitespace.foreground": "#4D4D4D40",
    "editorIndentGuide.background": "#4D4D4D20",
    "editorIndentGuide.activeBackground": "#80808060",
    "activityBar.background": "#F0F0F0",
    "activityBar.foreground": "#1A1A1A",
    "activityBar.inactiveForeground": "#1A1A1A60",
    "activityBarBadge.background": "#808080",
    "activityBarBadge.foreground": "#F0F0F0",
    "sideBar.background": "#F2F2F2",
    "sideBar.foreground": "#1A1A1A",
    "sideBarSectionHeader.background": "#F0F0F0",
    "statusBar.background": "#808080",
    "statusBar.foreground": "#F0F0F0",
    "statusBar.noFolderBackground": "#808080",
    "titleBar.activeBackground": "#F0F0F0",
    "titleBar.activeForeground": "#1A1A1A",
    "tab.activeBackground": "#F0F0F0",
    "tab.activeForeground": "#1A1A1A",
    "tab.inactiveBackground": "#D8D8D8",
    "tab.inactiveForeground": "#1A1A1A80",
    "terminal.background": "#F0F0F0",
    "terminal.foreground": "#1A1A1A"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#4D4D4D"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#808080"
      }
    },
    {
      "scope": "string.regexp",
      "settings": {
        "foreground": "#808080"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#808080"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#808080",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#808080",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#808080"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#808080",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#808080"
      }
    },
    {
      "scope": "entity.name.class",
      "settings": {
        "foreground": "#808080",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "entity.name.type",
      "settings": {
        "foreground": "#808080"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#1A1A1A"
      }
    },
    {
      "scope": "variable.parameter",
      "settings": {
        "foreground": "#808080",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "variable.other.property",
      "settings": {
        "foreground": "#808080"
      }
    },
    {
      "scope": "punctuation",
      "settings": {
        "foreground": "#1A1A1AB0"
      }
    }
  ]
}