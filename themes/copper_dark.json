{
  "name": "Themixir Copper Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#0A0500",
    "editor.foreground": "#F1E3D6",
    "editor.selectionBackground": "#B8733380",
    "editor.lineHighlightBackground": "#090500",
    "editorCursor.foreground": "#B87333",
    "editorWhitespace.foreground": "#935C2940",
    "editorIndentGuide.background": "#935C2920",
    "editorIndentGuide.activeBackground": "#B8733360",
    "activityBar.background": "#0A0500",
    "activityBar.foreground": "#F1E3D6",
    "activityBar.inactiveForeground": "#F1E3D660",
    "activityBarBadge.background": "#B87333",
    "activityBarBadge.foreground": "#0A0500",
    "sideBar.background": "#090500",
    "sideBar.foreground": "#F1E3D6",
    "sideBarSectionHeader.background": "#0A0500",
    "statusBar.background": "#B87333",
    "statusBar.foreground": "#0A0500",
    "statusBar.noFolderBackground": "#B87333",
    "titleBar.activeBackground": "#0A0500",
    "titleBar.activeForeground": "#F1E3D6",
    "tab.activeBackground": "#0A0500",
    "tab.activeForeground": "#F1E3D6",
    "tab.inactiveBackground": "#090500",
    "tab.inactiveForeground": "#F1E3D680",
    "terminal.background": "#0A0500",
    "terminal.foreground": "#F1E3D6"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#935C29"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#B87333"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#B87333"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#B87333",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#B87333"
      }
    },
    {
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#B87333"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#F1E3D6"
      }
    },
    {
      "scope": "punctuation",
      "settings": {
        "foreground": "#F1E3D6B0"
      }
    }
  ]
}