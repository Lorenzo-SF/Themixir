{
  "name": "Themixir Blue Deep",
  "type": "dark",
  "colors": {
    "editor.background": "#01242A",
    "editor.foreground": "#B4E9F2",
    "editor.selectionBackground": "#06B6D480",
    "editor.lineHighlightBackground": "#012026",
    "editorCursor.foreground": "#06B6D4",
    "editorWhitespace.foreground": "#0592AA40",
    "editorIndentGuide.background": "#0592AA20",
    "editorIndentGuide.activeBackground": "#06B6D460",
    "activityBar.background": "#01242A",
    "activityBar.foreground": "#B4E9F2",
    "activityBar.inactiveForeground": "#B4E9F260",
    "activityBarBadge.background": "#06B6D4",
    "activityBarBadge.foreground": "#01242A",
    "sideBar.background": "#012026",
    "sideBar.foreground": "#B4E9F2",
    "sideBarSectionHeader.background": "#01242A",
    "statusBar.background": "#06B6D4",
    "statusBar.foreground": "#01242A",
    "statusBar.noFolderBackground": "#06B6D4",
    "titleBar.activeBackground": "#01242A",
    "titleBar.activeForeground": "#B4E9F2",
    "tab.activeBackground": "#01242A",
    "tab.activeForeground": "#B4E9F2",
    "tab.inactiveBackground": "#012026",
    "tab.inactiveForeground": "#B4E9F280",
    "terminal.background": "#01242A",
    "terminal.foreground": "#B4E9F2"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#0592AA"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#064FD4"
      }
    },
    {
      "scope": "string.regexp",
      "settings": {
        "foreground": "#B6D406"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#D42406"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#D42406",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#06B6D4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#06B6D4"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#D42406",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#D406B6"
      }
    },
    {
      "scope": "entity.name.class",
      "settings": {
        "foreground": "#8B06D4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "entity.name.type",
      "settings": {
        "foreground": "#D42406"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#B4E9F2"
      }
    },
    {
      "scope": "variable.parameter",
      "settings": {
        "foreground": "#06D48B",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "variable.other.property",
      "settings": {
        "foreground": "#D4064F"
      }
    },
    {
      "scope": "punctuation",
      "settings": {
        "foreground": "#B4E9F2B0"
      }
    }
  ]
}