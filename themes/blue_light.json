{
  "name": "Themixir Blue Light",
  "type": "light",
  "colors": {
    "editor.background": "#F0F0F8",
    "editor.foreground": "#011F27",
    "editor.selectionBackground": "#059AC180",
    "editor.lineHighlightBackground": "#F2F2F9",
    "editorCursor.foreground": "#059AC1",
    "editorWhitespace.foreground": "#035C7440",
    "editorIndentGuide.background": "#035C7420",
    "editorIndentGuide.activeBackground": "#059AC160",
    "activityBar.background": "#F0F0F8",
    "activityBar.foreground": "#011F27",
    "activityBar.inactiveForeground": "#011F2760",
    "activityBarBadge.background": "#059AC1",
    "activityBarBadge.foreground": "#F0F0F8",
    "sideBar.background": "#F2F2F9",
    "sideBar.foreground": "#011F27",
    "sideBarSectionHeader.background": "#F0F0F8",
    "statusBar.background": "#059AC1",
    "statusBar.foreground": "#F0F0F8",
    "statusBar.noFolderBackground": "#059AC1",
    "titleBar.activeBackground": "#F0F0F8",
    "titleBar.activeForeground": "#011F27",
    "tab.activeBackground": "#F0F0F8",
    "tab.activeForeground": "#011F27",
    "tab.inactiveBackground": "#D8D8DF",
    "tab.inactiveForeground": "#011F2780",
    "terminal.background": "#F0F0F8",
    "terminal.foreground": "#011F27"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#035C74"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#053CC1"
      }
    },
    {
      "scope": "string.regexp",
      "settings": {
        "foreground": "#9AC105"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#C12C05"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#C12C05",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#059AC1",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#059AC1"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#C12C05",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#C1059A"
      }
    },
    {
      "scope": "entity.name.class",
      "settings": {
        "foreground": "#8A05C1",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "entity.name.type",
      "settings": {
        "foreground": "#C12C05"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#011F27"
      }
    },
    {
      "scope": "variable.parameter",
      "settings": {
        "foreground": "#05C18A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "variable.other.property",
      "settings": {
        "foreground": "#C1053C"
      }
    },
    {
      "scope": "punctuation",
      "settings": {
        "foreground": "#011F27B0"
      }
    }
  ]
}